# ============================================================
# OCR_MQTT — Environment Variable Template
# Copy this file to .env and fill in your values.
# ============================================================

# Application
APP_NAME=Industrial OCR Monitoring System
APP_VERSION=1.0.0
DEBUG=false

# YOLOv8
YOLO_BASE_MODEL=yolov8n.pt
YOLO_EPOCHS=100
YOLO_IMG_SIZE=640
YOLO_BATCH=16
YOLO_CONF_THRESHOLD=0.25
YOLO_IOU_THRESHOLD=0.45

# PaddleOCR
OCR_LANG=en
OCR_USE_GPU=false
OCR_USE_ANGLE_CLS=true

# MQTT (update hostname if running outside Docker)
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_QOS=1

# MongoDB (update if using Atlas or auth)
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=ocr_db
MONGO_COLLECTION=ocr_results

# FastAPI
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=false
CORS_ORIGINS=*

# Logging
LOG_LEVEL=INFO
